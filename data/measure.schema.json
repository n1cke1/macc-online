{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://macc.kz/schema/measure.json",
  "title": "Measure",
  "description": "Authoring input object — the STRUCTURE of a measure. Mirrors src/lib/measure/schema.ts. HOW to fill each field, units, the MAC definition, the AST notation and sourcing rules live in the UI-help overlay (measure-ui-help.json: panels/fields/enums/sourcing/formulas) and the macc-measure-authoring skill (procedure/requirements/conventions/checks). Economics derives from created_technologies + materials; the legacy `economics` array is a fallback only. For a complete worked example, call get_measure('kz-2').",
  "type": "object",
  "required": ["id", "schema_version", "name", "sector_ref", "scope", "maturity_stage", "mechanism", "abatement"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "description": "Measure id, e.g. 'kz-2'." },
    "schema_version": { "type": "integer", "const": 1 },
    "name": { "$ref": "#/$defs/localized" },
    "sector_ref": { "$ref": "#/$defs/sectorCode", "description": "Primary sector (curve color/filter)." },
    "sectors": {
      "type": "array",
      "description": "Multi-sector span (CCS/CCUS). Each: sector + optional subsector.",
      "items": {
        "type": "object", "additionalProperties": false, "required": ["sector_ref"],
        "properties": { "sector_ref": { "$ref": "#/$defs/sectorCode" }, "subsector_ref": { "type": "string" } }
      }
    },
    "product_ref": { "type": "string", "description": "Product produced (displaces conventional production); optional for practices/capture." },
    "technology_ref": { "type": "string", "description": "Primary object (kept for the economics guardrail)." },
    "mechanism": { "enum": ["reduction", "removal"], "description": "Abatement mechanism (classification). Absent ⇒ reduction. Removal = CDR (BECCS/DACCS/nature-based); fossil-CO₂ capture is reduction." },
    "mechanism_subtype": { "enum": ["efficiency", "fuel_switch", "electrification", "process_change", "demand_reduction", "non_co2", "nature_based", "engineered"], "description": "Soft subtype tag (optional)." },
    "permanence": { "enum": ["short_lived", "durable"], "description": "Removal only: storage durability flag (optional)." },
    "baseline_basis": { "enum": ["comparison", "standalone"], "description": "§B axis (parallel to mechanism). comparison ⇒ service-unit baseline + comparison.service_unit_ref; standalone ⇒ absolute project footprint (CCS, agro). Optional until all measures are authored, then required." },
    "scope": { "enum": ["published", "draft"] },
    "owner_ref": { "type": "string", "description": "Identity claim from the write path (§9); the creator. Set by the server." },
    "maturity_stage": { "enum": ["raw", "computed"] },
    "review_status": { "enum": ["open", "accepted", "rejected", "wontfix"] },
    "comparison": {
      "type": "object", "additionalProperties": false,
      "description": "Service-unit baseline; present for baseline_basis='comparison'.",
      "properties": {
        "service_unit_ref": { "type": "string" }
      }
    },
    "flows": {
      "type": "object", "required": ["baseline", "project"], "additionalProperties": false,
      "description": "Resource flows per service unit (comparison measures). Empty at raw.",
      "properties": {
        "baseline": { "type": "array", "items": { "$ref": "#/$defs/flow" } },
        "project": { "type": "array", "items": { "$ref": "#/$defs/flow" } }
      }
    },
    "inputs": {
      "type": "object",
      "description": "Local engineering premises (cap, capacity factor, intensities…) referenced by formulas via ref:<key>. Each carries provenance.",
      "additionalProperties": { "$ref": "#/$defs/valueWithSource" }
    },
    "abatement": {
      "type": "object",
      "description": "Exactly one stage block, keyed by maturity_stage.",
      "additionalProperties": false,
      "properties": {
        "raw": {
          "type": "object", "required": ["share"], "additionalProperties": false,
          "properties": { "share": { "type": "number" }, "justification": { "type": "string" } }
        },
        "computed": {
          "type": "object", "required": ["formula_ref", "bindings"], "additionalProperties": false,
          "properties": {
            "formula_ref": { "type": "string" },
            "bindings": { "type": "object", "additionalProperties": { "$ref": "#/$defs/formulaBinding" } },
            "derived_share": { "type": "number", "readOnly": true }
          }
        },
        "formula": { "$ref": "#/$defs/ast", "description": "Inline abatement AST over the measure inputs (res:<id> EF / recursive computed leaves). Wins over the stage block; ports the Excel formula directly." },
        "formula_label": { "$ref": "#/$defs/localized" },
        "factor_ref": { "type": "string", "description": "§7 X-axis: names the measure input holding the per-unit abatement factor (abatement ÷ activity). That input's reference_ref is the corridor the `factor` guardrail checks against." }
      }
    },
    "created_technologies": {
      "type": "array", "description": "Objects the measure CREATES (build). Economics derives from these.",
      "items": { "$ref": "#/$defs/builtObject" }
    },
    "retired_technologies": {
      "type": "array", "description": "Objects the measure CLOSES; their CAPEX/OPEX are avoided (subtracted).",
      "items": { "$ref": "#/$defs/retiredObject" }
    },
    "materials": {
      "type": "array", "description": "Key material/fuel flows (OPEX). cost = qty × price / 1e6, signed by side.",
      "items": { "$ref": "#/$defs/material" }
    },
    "sources": {
      "type": "object",
      "description": "§6 provenance+binding for the measure's INPUT bare numbers, keyed by value path (e.g. 'created_technologies[0].capacity', 'materials[1].price'). A path is in `sources` (input) XOR `computed` (derived).",
      "additionalProperties": { "$ref": "#/$defs/valueSource" }
    },
    "computed": {
      "type": "object",
      "description": "§3 formulas for the measure's COMPUTED bare numbers, keyed by the same value paths (or a named intermediate like 'gas_intensity'). compute() evaluates these; never enter such a number by hand.",
      "additionalProperties": { "$ref": "#/$defs/computedValue" }
    },
    "economics": {
      "type": "object", "additionalProperties": false,
      "description": "LEGACY free-form CAPEX/OPEX line items — fallback for un-migrated measures only. Prefer created_technologies + materials.",
      "properties": {
        "capex": { "type": "array", "items": { "$ref": "#/$defs/valueWithSource" } },
        "opex": { "type": "array", "items": { "$ref": "#/$defs/valueWithSource" } },
        "revenue": { "type": "array", "items": { "$ref": "#/$defs/valueWithSource" } }
      }
    },
    "potential": {
      "type": "object", "required": ["ceiling_dim", "pool_ref"], "additionalProperties": false,
      "properties": {
        "ceiling_dim": { "enum": ["cut_resource", "output_product", "n_objects", "activity"] },
        "pool_ref": { "type": "string" },
        "combination_group": { "type": "string" },
        "limit": {
          "type": "object", "required": ["indicator_ref", "consumption_ref"], "additionalProperties": false,
          "properties": {
            "indicator_ref": { "type": "string" },
            "consumption_ref": { "type": "string" }
          }
        }
      }
    },
    "provenance_rollup": { "enum": ["high", "medium", "low"], "readOnly": true }
  },
  "$defs": {
    "localized": {
      "type": "object", "required": ["ru"], "additionalProperties": false,
      "properties": { "ru": { "type": "string" }, "en": { "type": "string" } }
    },
    "sectorCode": { "enum": ["1.A.1", "1.A.2", "1.A.3", "1.A.4", "1.B", "2", "3", "4", "5"] },
    "numberOrRef": {
      "description": "A scalar that is either a literal number or a live registry/input ref ({ref:'<key>'}). Refs use the resolver namespace: 'res:<id>#<key>', 'obj:<id>#<key>', 'prd:<id>#<key>', 'sub:<id>#<key>', 'glb:<key>', 'in:<key>', bare measure input key, or a JS path into the document. A ref leaves no duplicated copy on the measure — editing the source propagates here automatically.",
      "oneOf": [
        { "type": "number" },
        {
          "type": "object", "required": ["ref"], "additionalProperties": false,
          "properties": { "ref": { "type": "string", "description": "key the resolver understands" } }
        }
      ]
    },
    "flow": {
      "type": "object", "required": ["resource_ref", "qty_per_unit"], "additionalProperties": false,
      "properties": { "resource_ref": { "type": "string" }, "qty_per_unit": { "type": "number" }, "unit": { "type": "string" } }
    },
    "builtObject": {
      "type": "object", "required": ["technology_ref"], "additionalProperties": false,
      "description": "CAPEX = capex_musd ?? capacity × tech.capex_ud × (capex_ud_factor ?? 1) / 1e6. Scalar fields accept numberOrRef so a measure can point at the registry/inputs instead of carrying a duplicated copy.",
      "properties": {
        "technology_ref": { "type": "string", "description": "library object id" },
        "capacity": { "$ref": "#/$defs/numberOrRef" }, "unit": { "type": "string" },
        "capex_ud_factor": { "$ref": "#/$defs/numberOrRef", "description": "capacity unit → capex_ud denominator (e.g. MW→kW = 1000)" },
        "capex_musd": { "$ref": "#/$defs/numberOrRef", "description": "explicit CAPEX when not capacity-driven" },
        "opex_musd": { "$ref": "#/$defs/numberOrRef", "description": "annual OPEX line, signed" }
      }
    },
    "retiredObject": {
      "type": "object", "required": ["technology_ref"], "additionalProperties": false,
      "properties": {
        "technology_ref": { "type": "string" }, "capacity": { "$ref": "#/$defs/numberOrRef" }, "unit": { "type": "string" },
        "capex_ud_factor": { "$ref": "#/$defs/numberOrRef" },
        "maintenance_capex_musd": { "$ref": "#/$defs/numberOrRef", "description": "avoided maintenance CAPEX (subtracted)" },
        "opex_musd": { "$ref": "#/$defs/numberOrRef", "description": "avoided OPEX (signed)" }
      }
    },
    "material": {
      "type": "object", "required": ["resource_ref", "side"], "additionalProperties": false,
      "properties": {
        "resource_ref": { "type": "string" },
        "side": { "enum": ["new", "retired"], "description": "new = consumed (cost +); retired = freed (saving −)" },
        "qty": { "$ref": "#/$defs/numberOrRef" }, "price": { "$ref": "#/$defs/numberOrRef" },
        "cost_musd": { "$ref": "#/$defs/numberOrRef", "description": "explicit cost when qty/price aren't both known" },
        "unit": { "type": "string" }
      }
    },
    "provenance": {
      "type": "object", "required": ["source_type", "confidence"], "additionalProperties": false,
      "properties": {
        "source_type": { "enum": ["official_stat", "literature", "standard", "expert_estimate", "assumption", "placeholder"] },
        "citation": { "type": "string" }, "url": { "type": "string" }, "date": { "type": "string" },
        "confidence": { "enum": ["high", "medium", "low"] },
        "geo_applicability": { "enum": ["global", "kz_specific", "other_country"], "description": "§B geo-applicability: global (low geo-sensitivity) / kz_specific / other_country. State KZ-reliability in kz_reliability." },
        "kz_reliability": { "type": "string", "description": "§B short note on the number's reliability for assessing the measure in Kazakhstan." }
      }
    },
    "binding": {
      "type": "object", "required": ["mode"], "additionalProperties": false,
      "properties": {
        "mode": { "enum": ["reuse", "alt", "new", "derived"] },
        "ref": { "type": "string" }, "value": { "type": "number" },
        "divergence_reason": { "type": "string", "description": "required for mode=alt" }
      }
    },
    "valueWithSource": {
      "type": "object", "required": ["value", "provenance"], "additionalProperties": false,
      "properties": {
        "value": { "type": "number" }, "unit": { "type": "string" },
        "provenance": { "$ref": "#/$defs/provenance" }, "binding": { "$ref": "#/$defs/binding" },
        "reference_ref": { "type": "string", "description": "§7 — optional reference corridor this number is sanity-checked against (e.g. the per-unit factor named by abatement.factor_ref)." }
      }
    },
    "valueSource": {
      "type": "object", "required": ["provenance"], "additionalProperties": false,
      "properties": { "provenance": { "$ref": "#/$defs/provenance" }, "binding": { "$ref": "#/$defs/binding" } }
    },
    "computedValue": {
      "type": "object", "required": ["formula"], "additionalProperties": false,
      "properties": { "formula": { "$ref": "#/$defs/ast" }, "label": { "$ref": "#/$defs/localized" } }
    },
    "formulaBinding": {
      "oneOf": [
        { "type": "object", "required": ["ref"], "additionalProperties": false, "properties": { "ref": { "type": "string" } } },
        { "type": "object", "required": ["const"], "additionalProperties": false, "properties": { "const": { "type": "number" } } }
      ]
    },
    "ast": {
      "description": "Formula AST. A leaf is a bare number, {ref:key}, {slot:name} or {const:n}; a node is {op, args[]}. ref resolves: res:<id>→EF, a key with its own computed entry→its formula (recursive), else a measure input. ops: add/sub/mul/div/sum/pv/lookup + predicates lte/gte/between.",
      "oneOf": [
        { "type": "number" },
        { "type": "object", "required": ["ref"], "additionalProperties": false, "properties": { "ref": { "type": "string" } } },
        { "type": "object", "required": ["slot"], "additionalProperties": false, "properties": { "slot": { "type": "string" } } },
        { "type": "object", "required": ["const"], "additionalProperties": false, "properties": { "const": { "type": "number" } } },
        {
          "type": "object", "required": ["op", "args"], "additionalProperties": false,
          "properties": {
            "op": { "enum": ["add", "sub", "mul", "div", "sum", "pv", "lookup", "lte", "gte", "between"] },
            "args": { "type": "array", "items": { "$ref": "#/$defs/ast" } }
          }
        }
      ]
    }
  }
}
