# ─────────────────────────────────────────────────────────────────────────────
# Optional collaboration layer (Supabase). Leave these UNSET to ship the pure
# static core: the chart, live recalc, drill-down, scenarios and exports all work
# with zero backend. Set them to enable sign-in + anchored review comments.
#
# Copy to `.env.local` and fill in from your Supabase project
# (Project Settings → API). Both are PUBLIC values (anon key is RLS-guarded),
# safe to inline into the static bundle.
# ─────────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Server-side only (NOT inlined into the bundle) ───────────────────────────
# Used by the `notify` Edge Function for review email notifications.
# Set these as Supabase Edge Function secrets, not in the client build:
#   supabase secrets set RESEND_API_KEY=... NOTIFY_FROM=... SITE_URL=...
# RESEND_API_KEY=
# NOTIFY_FROM=MACC KZ <noreply@your-domain.org>
# SITE_URL=https://macc-kz.pages.dev
